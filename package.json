{
  "name": "tangleflow",
  "version": "0.1.0",
  "description": "Converts GitHub actions into Tangled workflows and vice versa.",
  "main": "./lib/main.js",
  "bin": {
    "tangleflow": "./lib/cli.js"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./lib/main.d.ts",
      "default": "./lib/main.js"
    }
  },
  "files": [
    "lib",
    "!lib/**/*.test.js",
    "!lib/**/*.test.d.ts"
  ],
  "scripts": {
    "build:clean": "node -e \"require('fs').rmSync('./lib', { recursive: true, force: true })\"",
    "build": "npm run build:clean && tsc",
    "lint:js": "oxlint src",
    "lint:format": "oxfmt --check src",
    "lint": "npm run lint:js && npm run lint:format",
    "format": "oxfmt --write src",
    "test": "vitest run",
    "update-github-types": "node scripts/update-github-types.ts && npm run format"
  },
  "keywords": [
    "tangled",
    "actions",
    "gha",
    "github"
  ],
  "author": "James Garbutt (https://github.com/43081j)",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://github.com/43081j/tangleflow#readme",
  "bugs": {
    "url": "https://github.com/43081j/tangleflow/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/43081j/tangleflow.git"
  },
  "peerDependencies": {
    "yaml": "^2.9.0"
  },
  "peerDependenciesMeta": {
    "yaml": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "@vitest/coverage-v8": "^4.1.5",
    "json-schema-to-typescript": "^15.0.4",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.63.0",
    "typescript": "^7.0.2",
    "vitest": "^4.1.5",
    "yaml": "^2.9.0"
  }
}
